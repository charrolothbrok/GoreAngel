---
interface Vestimenta {
  etiqueta?: string
  etiqueta_en?: string
  descripcion?: string
  descripcion_en?: string
  nota?: string
  nota_en?: string
  fotos?: string[]
  fotos_hombres?: string[]
  fotos_mujeres?: string[]
}

interface Props {
  data?: Vestimenta
  t?: Record<string, string>
  lang?: string
}

const { data = {}, t = {}, lang = 'es' } = Astro.props

// Elige el idioma correcto (con respaldo al otro si está vacío)
const pick = (es?: string, en?: string) =>
  (lang === 'en' ? en || es : es || en) || ''

const etiqueta = pick(data.etiqueta, data.etiqueta_en) || 'Formal'
const descripcion =
  pick(data.descripcion, data.descripcion_en) ||
  (lang === 'en'
    ? 'We kindly ask you to dress formally to join us on this special day.'
    : 'Te pedimos vestir formal para acompañarnos en este día tan especial.')
const nota = pick(data.nota, data.nota_en)
// Compatibilidad: fotos antiguas (sin dividir) van al grupo de hombres
const fotosHombres = data.fotos_hombres || data.fotos || []
const fotosMujeres = data.fotos_mujeres || []
---

<section id="vestimenta" class="dress">
  <div class="shell dress__inner" data-reveal>
    <p class="eyebrow">{t.dress_eyebrow || 'Código de vestimenta'}</p>

    <div class="dress__ornament" aria-hidden="true">
      <span class="dress__line"></span>
      <svg class="dress__tie" viewBox="0 0 56 28" fill="currentColor">
        <polygon points="28,14 5,4 5,24" />
        <polygon points="28,14 51,4 51,24" />
        <rect x="25" y="9.5" width="6" height="9" rx="1.6" />
      </svg>
      <span class="dress__line"></span>
    </div>

    <h2 class="dress__etiqueta">{etiqueta}</h2>
    <p class="dress__desc">{descripcion}</p>

    {
      nota && (
        <p class="dress__nota">
          <span class="dress__nota-mark">✦</span>
          {nota}
        </p>
      )
    }

    {
      fotosHombres.length > 0 && (
        <div class="dress__grupo">
          <p class="dress__grupo-title">{t.dress_hombres || 'Caballeros'}</p>
          <div class="dress__fotos">
            {fotosHombres.map((url) => (
              <figure class="dress__foto">
                <img src={url} alt="Ejemplo de vestimenta" loading="lazy" />
              </figure>
            ))}
          </div>
        </div>
      )
    }

    {
      fotosMujeres.length > 0 && (
        <div class="dress__grupo">
          <p class="dress__grupo-title">{t.dress_mujeres || 'Damas'}</p>
          <div class="dress__fotos">
            {fotosMujeres.map((url) => (
              <figure class="dress__foto">
                <img src={url} alt="Ejemplo de vestimenta" loading="lazy" />
              </figure>
            ))}
          </div>
        </div>
      )
    }
  </div>
</section>

<style>
  .dress {
    padding-block: clamp(5rem, 12vw, 9rem);
  }

  .dress__inner {
    max-width: 36rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .dress__ornament {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    margin-block: 0.6rem;
  }
  .dress__line {
    display: block;
    width: clamp(2.5rem, 8vw, 4rem);
    height: 1px;
    background: linear-gradient(to right, transparent, var(--color-gold));
  }
  .dress__line:last-child {
    background: linear-gradient(to left, transparent, var(--color-gold));
  }
  .dress__tie {
    width: clamp(2.4rem, 7vw, 3rem);
    height: auto;
    color: var(--color-sage-dark);
  }

  .dress__etiqueta {
    font-size: clamp(2.2rem, 7vw, 3.6rem);
    line-height: 1;
  }

  .dress__desc {
    color: var(--color-ink-soft);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 30rem;
  }

  .dress__nota {
    margin-top: 0.8rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--color-sage-dark);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .dress__nota-mark {
    color: var(--color-gold);
    font-style: normal;
  }

  .dress__grupo {
    margin-top: 2.5rem;
    width: 100%;
  }
  .dress__grupo-title {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    color: var(--color-sage-dark);
    margin-bottom: 1rem;
  }

  .dress__fotos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.8rem;
  }
  .dress__foto {
    width: clamp(120px, 30vw, 180px);
    aspect-ratio: 3 / 4;
    margin: 0;
    overflow: hidden;
    border: 1px solid var(--color-hairline);
  }
  .dress__foto img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.2s var(--ease-elegant);
  }
  .dress__foto:hover img {
    transform: scale(1.05);
  }
</style>
