---
// Render en el servidor en cada visita: así los cambios del admin
// (lugares, itinerario, vestimenta, música) se ven al instante.
export const prerender = false

import Layout from '../layouts/Layout.astro'
import Hero from '../components/Hero.astro'
import Ceremony from '../components/Ceremony.astro'
import ItineraryShowcase from '../components/ItineraryShowcase.vue'
import DressCode from '../components/DressCode.astro'
import Petals from '../components/Petals.astro'
import Welcome from '../components/Welcome.vue'
import Countdown from '../components/Countdown.vue'
import Gallery from '../components/Gallery.vue'
import Rsvp from '../components/Rsvp.vue'
import GiftTable from '../components/GiftTable.vue'
import MusicPlayer from '../components/MusicPlayer.vue'
import { supabase } from '../lib/supabase'
import { getLang, translations } from '../i18n'

// Idioma (español por defecto, ?lang=en para inglés)
const lang = getLang(Astro.url)
const t = translations[lang]
const otroLang = lang === 'es' ? 'en' : 'es'

// Lee toda la configuración de una vez (la llena el panel admin en la Fase 3)
const { data: configRows } = await supabase
  .from('configuracion')
  .select('clave, valor')

function leerConfig(clave: string): any {
  const row = configRows?.find((r) => r.clave === clave)
  if (!row?.valor) return {}
  try {
    return JSON.parse(row.valor)
  } catch {
    return {}
  }
}

const venues = leerConfig('venues')
const ceremonia = venues.ceremonia
const recepcion = venues.recepcion
const mesaRegalos = leerConfig('mesa_regalos')
const musica = leerConfig('musica_url')
const itinerario = leerConfig('itinerario')
const vestimenta = leerConfig('vestimenta')

// Portada editable (lugar + texto de intro)
const portada = leerConfig('portada')
const lugar = portada.lugar || 'Zacatecas, México'
const introTexto =
  portada.intro_texto ||
  'Después de un camino juntos, hemos decidido unir nuestras vidas. Nos encantaría que seas parte de este día.'
---

<Layout lang={lang}>
  <!-- Botón de idioma -->
  <a class="lang-toggle" href={`?lang=${otroLang}`} aria-label="Cambiar idioma">
    <span class={lang === 'es' ? 'lang-on' : ''}>ES</span>
    <span class="lang-sep">/</span>
    <span class={lang === 'en' ? 'lang-on' : ''}>EN</span>
  </a>

  <Welcome novio="Ángel" novia="Goretti" fecha={t.fecha} t={t} client:load />

  <Petals />

  <Hero lugar={lugar} fecha={t.fecha} eyebrow={t.hero_eyebrow} />

  <!-- Intro / cuenta regresiva -->
  <section id="historia" class="section section--center">
    <div class="shell">
      <p class="eyebrow" data-reveal>{t.intro_eyebrow}</p>
      <p class="lead" data-reveal style="--reveal-delay: 100ms;">
        {introTexto}
      </p>
      <div data-reveal style="--reveal-delay: 220ms;">
        <Countdown t={t} client:visible />
      </div>
    </div>
  </section>

  <!-- Galería -->
  <section id="galeria" class="section">
    <div class="shell">
      <header class="section__head" data-reveal>
        <p class="eyebrow">{t.gallery_eyebrow}</p>
        <h2 class="section__title">{t.gallery_title}</h2>
      </header>
    </div>
    <div data-reveal>
      <Gallery t={t} client:visible />
    </div>
  </section>

  <!-- Detalles del evento -->
  <Ceremony ceremonia={ceremonia} recepcion={recepcion} t={t} />

  <!-- Itinerario del día (interactivo) -->
  <section id="itinerario" class="section">
    <div class="shell">
      <header class="section__head" data-reveal>
        <p class="eyebrow">{t.itin_eyebrow}</p>
        <h2 class="section__title">{t.itin_title}</h2>
      </header>
    </div>
    <div data-reveal>
      <ItineraryShowcase eventos={itinerario.eventos} client:visible />
    </div>
  </section>

  <!-- Código de vestimenta -->
  <DressCode data={vestimenta} t={t} />

  <!-- Mesa de regalos -->
  <section id="regalos" class="section">
    <div class="shell">
      <header class="section__head" data-reveal>
        <p class="eyebrow">{t.gifts_eyebrow}</p>
        <h2 class="section__title">{t.gifts_title}</h2>
      </header>
      <GiftTable config={mesaRegalos} t={t} client:visible />
    </div>
  </section>

  <!-- RSVP -->
  <section id="rsvp" class="section section--rsvp">
    <div class="shell">
      <header class="section__head" data-reveal>
        <p class="eyebrow">{t.rsvp_eyebrow}</p>
        <h2 class="section__title">{t.rsvp_title}</h2>
        <p class="section__sub">{t.rsvp_sub}</p>
      </header>
      <div data-reveal style="--reveal-delay: 120ms;">
        <Rsvp t={t} client:visible />
      </div>
    </div>
  </section>

  <footer class="footer">
    <p class="footer__names">Ángel &amp; Goretti</p>
    <p class="footer__date">22 · 08 · 2026</p>
  </footer>

  <!-- Música de fondo (aparece solo si hay URL configurada) -->
  <MusicPlayer url={musica.url} t={t} client:load />
</Layout>

<style>
  /* Botón de idioma */
  .lang-toggle {
    position: fixed;
    top: clamp(1rem, 3vw, 1.6rem);
    left: clamp(1rem, 4vw, 2rem);
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.9rem;
    border: 1px solid var(--color-hairline);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-bone) 80%, transparent);
    backdrop-filter: blur(8px);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    color: var(--color-ink-soft);
    text-decoration: none;
    transition: transform 0.4s var(--ease-spring), border-color 0.3s;
  }
  .lang-toggle:hover { transform: scale(1.05); border-color: var(--color-sage); }
  .lang-toggle .lang-on { color: var(--color-sage); font-weight: 600; }
  .lang-sep { color: var(--color-sand); }

  .section {
    padding-block: clamp(5rem, 12vw, 9rem);
  }

  .section--center {
    text-align: center;
  }

  .section--center .lead {
    max-width: 36rem;
    margin: 1.2rem auto clamp(2.5rem, 6vw, 4rem);
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    line-height: 1.6;
    color: var(--color-ink-soft);
  }

  .section__head {
    text-align: center;
    margin-bottom: clamp(2.5rem, 7vw, 4.5rem);
  }

  .section__title {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    margin-top: 0.6rem;
  }

  .section__sub {
    margin-top: 1rem;
    color: var(--color-ink-soft);
  }

  .section--rsvp {
    background:
      radial-gradient(100% 60% at 50% 0%, rgba(217, 199, 179, 0.16), transparent 60%);
  }

  .footer {
    text-align: center;
    padding-block: clamp(3rem, 8vw, 5rem);
    border-top: 1px solid var(--color-hairline);
  }

  .footer__names {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 5vw, 2.6rem);
  }

  .footer__date {
    margin-top: 0.4rem;
    letter-spacing: 0.3em;
    font-size: 0.8rem;
    color: var(--color-ink-soft);
  }
</style>
